# ───── biblioHack — local dev env ─────
# Copy to .env and adjust as needed. Never commit a real .env.

# ───── Postgres ─────
POSTGRES_USER=bibliohack
POSTGRES_PASSWORD=bibliohack
POSTGRES_DB=bibliohack
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Async URL used by the backend (asyncpg)
DATABASE_URL=postgresql+asyncpg://bibliohack:bibliohack@postgres:5432/bibliohack

# Sync URL used by Alembic (psycopg)
DATABASE_URL_SYNC=postgresql+psycopg://bibliohack:bibliohack@postgres:5432/bibliohack

# ───── Redis ─────
REDIS_URL=redis://redis:6379/0

# ───── FastAPI ─────
APP_ENV=development           # development | test | production
APP_LOG_LEVEL=DEBUG
APP_CORS_ORIGINS=http://localhost:4321

# ───── Scraper ─────
SCRAPER_USER_AGENT=bibliohack/0.1 (+https://github.com/your-user/biblioHack)
SCRAPER_MIN_INTERVAL_SECONDS=1.0
SCRAPER_MAX_INTERVAL_SECONDS=1.8
SCRAPER_DAILY_REQUEST_CAP=30000

# ───── OpenRouter ─────
# Get a key at https://openrouter.ai. Free models are fine for dev.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/auto:free

# ───── Embeddings ─────
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu          # cpu | cuda | mps

# ───── Frontend (Astro) ─────
PUBLIC_API_BASE_URL=http://localhost:8800

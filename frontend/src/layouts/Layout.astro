---
import "../styles/global.css";

import Container from "@/components/ui/container.astro";
import { ThemeToggle } from "@/components/ThemeToggle";
import { UserMenu } from "@/components/UserMenu";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Reverse catalog of the Andalusian public libraries." } = Astro.props;
const apiBaseUrl = import.meta.env.PUBLIC_API_BASE_URL ?? "http://localhost:8800";
---

<!doctype html>
<html lang="es" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    {
      /*
        Theme bootstrap — runs synchronously before the body renders so we
        never flash the wrong theme. Reads `localStorage.theme` ("light" |
        "dark" | "system") and falls back to `prefers-color-scheme`.
        Wrapped in is:inline so Astro emits it verbatim with no JS bundle.
        */
    }
    <script is:inline>
      (() => {
        try {
          const stored = window.localStorage.getItem("theme");
          const sysDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
          const isDark = stored === "dark" || (stored !== "light" && sysDark);
          document.documentElement.classList.toggle("dark", isDark);
        } catch {
          /* ignore — fall back to default light theme */
        }
      })();
    </script>
  </head>
  <body class="flex min-h-screen flex-col bg-background font-sans text-foreground">
    <header class="border-b border-border">
      <Container class="flex items-center justify-between py-4">
        <a href="/" class="font-serif text-xl font-semibold tracking-tight text-foreground">
          biblioHack
        </a>
        <div class="flex items-center gap-2 text-sm text-muted-foreground">
          <nav class="flex items-center gap-4">
            <a href="/" class="transition-colors hover:text-foreground">Inicio</a>
            <a href="/browse" class="transition-colors hover:text-foreground">Explorar</a>
            <a href="/shelf" class="transition-colors hover:text-foreground">Mi estantería</a>
            <a href="/recommendations" class="transition-colors hover:text-foreground">
              Recomendaciones
            </a>
            <UserMenu apiBaseUrl={apiBaseUrl} client:only="react" />
          </nav>
          <ThemeToggle client:load />
        </div>
      </Container>
    </header>

    <main class="flex-1 py-10">
      <Container>
        <slot />
      </Container>
    </main>

    <footer class="border-t border-border py-6">
      <Container class="space-y-2 text-center text-xs text-muted-foreground">
        <p>
          Información obtenida del Portal de la Junta de Andalucía. Datos públicos de la Red de
          Bibliotecas Públicas de Andalucía (CC-BY 3.0 ES). Proyecto personal sin ánimo de lucro.
          <a
            href="https://github.com/jarcos/biblioHack"
            class="text-foreground underline-offset-4 hover:underline"
          >
            Código
          </a>
        </p>
        <p>
          <a href="/privacy" class="underline-offset-4 hover:underline">Privacidad</a>
          {" · "}
          <a href="/terms" class="underline-offset-4 hover:underline">Condiciones de uso</a>
        </p>
      </Container>
    </footer>
  </body>
</html>

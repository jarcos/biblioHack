---
import Layout from "../layouts/Layout.astro";
import { ForgotPasswordForm } from "@/components/auth/ForgotPasswordForm";

const apiBaseUrl = import.meta.env.PUBLIC_API_BASE_URL ?? "http://localhost:8800";
---

<Layout title="biblioHack — recuperar contraseña">
  <section class="mx-auto max-w-md space-y-8">
    <header class="space-y-3">
      <h1 class="font-serif text-3xl font-semibold leading-tight tracking-tight">
        Recuperar contraseña
      </h1>
      <p class="text-base text-muted-foreground">
        Te enviaremos un enlace para crear una contraseña nueva.
      </p>
    </header>
    <ForgotPasswordForm apiBaseUrl={apiBaseUrl} client:only="react" />
  </section>
</Layout>

---
import Layout from "../layouts/Layout.astro";
import HelloIsland from "../components/HelloIsland";
import { SearchBox } from "@/components/SearchBox";
import { Button } from "@/components/ui/button";
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/ui/card";

const apiBaseUrl = import.meta.env.PUBLIC_API_BASE_URL ?? "http://localhost:8800";
---

<Layout title="biblioHack — inicio">
  <section class="space-y-12">
    <header class="max-w-3xl space-y-4">
      <p class="text-xs uppercase tracking-[0.18em] text-muted-foreground">
        Red de Bibliotecas Públicas de Andalucía · espejo
      </p>
      <h1 class="font-serif text-4xl font-semibold leading-tight tracking-tight sm:text-5xl">
        Un catálogo inverso para encontrar el libro que no sabías que buscabas.
      </h1>
      <p class="max-w-2xl text-base text-muted-foreground">
        Proyecto personal. Espejo del catálogo público con búsqueda en castellano (con y sin
        tildes), historial de disponibilidad por sucursal y un recomendador basado en lo que ya has
        leído.
      </p>
      <div class="flex gap-3 pt-2">
        <Button size="lg">Empezar a buscar</Button>
        <Button size="lg" variant="ghost">Cómo funciona</Button>
      </div>
    </header>

    <SearchBox apiBaseUrl={apiBaseUrl} client:load />

    <Card>
      <CardHeader>
        <CardTitle className="font-sans text-base font-medium">API status</CardTitle>
        <CardDescription> Comprobación en vivo de la conexión con el backend. </CardDescription>
      </CardHeader>
      <CardContent>
        <HelloIsland client:load apiBaseUrl={apiBaseUrl} />
      </CardContent>
    </Card>

    <p class="text-xs text-muted-foreground">
      M2 (en curso) — historial de disponibilidad. La búsqueda está conectada a <code
        >/catalog/search</code
      >; faltan los registros que poblará el worker.
    </p>
  </section>
</Layout>

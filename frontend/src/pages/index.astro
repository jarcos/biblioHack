---
import Layout from "../layouts/Layout.astro";
import HelloIsland from "../components/HelloIsland";
import { Badge } from "@/components/ui/badge";
import { Button } from "@/components/ui/button";
import { Input } from "@/components/ui/input";
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/ui/card";

const apiBaseUrl = import.meta.env.PUBLIC_API_BASE_URL ?? "http://localhost:8800";
---

<Layout title="biblioHack — inicio">
  <section class="space-y-12">
    <header class="max-w-3xl space-y-4">
      <p class="text-xs uppercase tracking-[0.18em] text-muted-foreground">
        Red de Bibliotecas Públicas de Andalucía · espejo
      </p>
      <h1 class="font-serif text-4xl font-semibold leading-tight tracking-tight sm:text-5xl">
        Un catálogo inverso para encontrar el libro que no sabías que buscabas.
      </h1>
      <p class="max-w-2xl text-base text-muted-foreground">
        Proyecto personal. Espejo del catálogo público con búsqueda en castellano (con y sin
        tildes), historial de disponibilidad por sucursal y un recomendador basado en lo que ya has
        leído.
      </p>
      <div class="flex gap-3 pt-2">
        <Button size="lg">Empezar a buscar</Button>
        <Button size="lg" variant="ghost">Cómo funciona</Button>
      </div>
    </header>

    <Card>
      <CardHeader>
        <CardTitle>Buscar en el catálogo</CardTitle>
        <CardDescription>
          Próximamente — el endpoint <code>/catalog/search</code> ya está activo; esta caja se conecta
          en el siguiente commit.
        </CardDescription>
      </CardHeader>
      <CardContent>
        <form class="flex gap-2" autocomplete="off">
          <Input
            type="search"
            placeholder="Cien años de soledad, García Márquez, 821.134.2…"
            aria-label="Buscar en el catálogo"
          />
          <Button type="submit">Buscar</Button>
        </form>
      </CardContent>
    </Card>

    <div class="grid gap-6 md:grid-cols-2">
      <Card>
        <CardHeader>
          <CardTitle>Cien años de soledad</CardTitle>
          <CardDescription>Gabriel García Márquez · 1967</CardDescription>
        </CardHeader>
        <CardContent className="space-y-3">
          <p class="text-sm text-muted-foreground">
            Editorial Sudamericana. Disponible en 3 bibliotecas de la red.
          </p>
          <div class="flex flex-wrap gap-2">
            <Badge variant="available">Disponible · Huelva</Badge>
            <Badge variant="loaned">Prestado · Sevilla</Badge>
            <Badge variant="reserved">Reservado · Málaga</Badge>
          </div>
        </CardContent>
      </Card>

      <Card>
        <CardHeader>
          <CardTitle>La sombra del viento</CardTitle>
          <CardDescription>Carlos Ruiz Zafón · 2001</CardDescription>
        </CardHeader>
        <CardContent className="space-y-3">
          <p class="text-sm text-muted-foreground">
            Planeta. El primer volumen de El cementerio de los libros olvidados.
          </p>
          <div class="flex flex-wrap gap-2">
            <Badge variant="available">Disponible · Huelva</Badge>
            <Badge variant="unavailable">En inventario · Cádiz</Badge>
            <Badge variant="unknown">Sin datos · Almería</Badge>
          </div>
        </CardContent>
      </Card>
    </div>

    <Card>
      <CardHeader>
        <CardTitle className="font-sans text-base font-medium">API status</CardTitle>
        <CardDescription> Comprobación en vivo de la conexión con el backend. </CardDescription>
      </CardHeader>
      <CardContent>
        <HelloIsland client:load apiBaseUrl={apiBaseUrl} />
      </CardContent>
    </Card>

    <p class="text-xs text-muted-foreground">
      M2 (en curso) — historial de disponibilidad. Próximo: conectar la búsqueda al endpoint <code
        >/catalog/search</code
      >.
    </p>
  </section>
</Layout>

---
import Layout from "../layouts/Layout.astro";
import { AuthGate } from "@/components/auth/AuthGate";
import { BookShelf } from "@/components/BookShelf";
import { ShelfImport } from "@/components/ShelfImport";

// Static shell; the islands fetch client-side. AuthGate redirects to /login
// when there is no session (the shelf is per-user since the identity
// milestone, and this site has no SSR to guard it server-side).
const apiBaseUrl = import.meta.env.PUBLIC_API_BASE_URL ?? "http://localhost:8800";
---

<Layout title="biblioHack — mi estantería">
  <section class="space-y-8">
    <header class="max-w-3xl space-y-3">
      <h1 class="font-serif text-3xl font-semibold leading-tight tracking-tight">Mi estantería</h1>
      <p class="text-base text-muted-foreground">
        Tu biblioteca de Goodreads, cruzada con el catálogo de la Red de Bibliotecas de Andalucía.
        Los libros encontrados muestran portada y disponibilidad en vivo y enlazan a su ficha; el
        resto se volverá a cruzar a medida que crezca el catálogo.
      </p>
    </header>

    <AuthGate apiBaseUrl={apiBaseUrl} client:only="react">
      <ShelfImport apiBaseUrl={apiBaseUrl} />
      <BookShelf apiBaseUrl={apiBaseUrl} />
    </AuthGate>
  </section>
</Layout>
